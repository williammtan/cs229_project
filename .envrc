# direnv config — auto-exports when you cd into this directory.
# Pins Modal to the per-repo `etm-clf` profile so `uv run modal ...` from this
# repo never accidentally uses your default Modal credentials.
#
# Setup (one-time):
#   1. uv run modal token new --profile etm-clf    # opens browser, stores in ~/.modal.toml
#   2. direnv allow                                # authorizes this .envrc
export MODAL_PROFILE=etm-clf
